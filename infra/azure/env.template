# ──────────────────────────────────────────────────────────
# Azure Container Apps — Environment Variables Template
# Copy to .env and fill in your values before running scripts
# ──────────────────────────────────────────────────────────

# Azure basics
AZURE_RESOURCE_GROUP=travel-plan-rg
AZURE_LOCATION=eastus
AZURE_SUBSCRIPTION_ID=

# Azure Container Registry
ACR_NAME=travelplanacr

# Container Apps Environment
CONTAINER_ENV_NAME=travel-plan-env
LOG_ANALYTICS_WORKSPACE=travel-plan-logs

# Azure Event Hubs (Kafka replacement)
EVENTHUB_NAMESPACE=travel-plan-events
EVENTHUB_SKU=Standard

# Supabase (existing — same for all services)
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# Database connection strings (per-service Supabase pooler URLs)
