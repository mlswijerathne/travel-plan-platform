# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS Configuration (Spring Gateway — local dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CORS Origin for Caddy (production only)
CORS_ORIGIN=https://travel-plan.live

# Domain for Caddy HTTPS reverse proxy (production only)
DOMAIN=api.travel-plan.live

# Eureka Configuration
EUREKA_URL=http://localhost:8761/eureka/

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# Database Credentials (per service - each uses its own Neon DB)
# Tourist Service
TOURIST_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
TOURIST_DB_USERNAME=neondb_owner
TOURIST_DB_PASSWORD=your-password

# Hotel Service
HOTEL_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
HOTEL_DB_USERNAME=neondb_owner
HOTEL_DB_PASSWORD=your-password

# Tour Guide Service
TOUR_GUIDE_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
TOUR_GUIDE_DB_USERNAME=neondb_owner
TOUR_GUIDE_DB_PASSWORD=your-password

# Vehicle Service
VEHICLE_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
VEHICLE_DB_USERNAME=neondb_owner
VEHICLE_DB_PASSWORD=your-password

# Booking Service
BOOKING_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
BOOKING_DB_USERNAME=neondb_owner
BOOKING_DB_PASSWORD=your-password

# Itinerary Service
ITINERARY_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
ITINERARY_DB_USERNAME=neondb_owner
ITINERARY_DB_PASSWORD=your-password

# Review Service
REVIEW_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
REVIEW_DB_USERNAME=neondb_owner
REVIEW_DB_PASSWORD=your-password

# Trip Plan Service
TRIP_PLAN_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
TRIP_PLAN_DB_USERNAME=neondb_owner
TRIP_PLAN_DB_PASSWORD=your-password

# Ecommerce Service
ECOMMERCE_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
ECOMMERCE_DB_USERNAME=neondb_owner
ECOMMERCE_DB_PASSWORD=your-password

# Event Service
EVENT_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
EVENT_DB_USERNAME=neondb_owner
EVENT_DB_PASSWORD=your-password

# Azure Blob Storage (shared image storage for all services)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;EndpointSuffix=core.windows.net;AccountName=your-account;AccountKey=your-key;BlobEndpoint=https://your-account.blob.core.windows.net/

# AI Agent Service
AI_AGENT_DB_URL=jdbc:postgresql://your-neon-host/neondb?sslmode=require
AI_AGENT_DB_USERNAME=neondb_owner
AI_AGENT_DB_PASSWORD=your-password
OPENAI_API_KEY=your-openai-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
